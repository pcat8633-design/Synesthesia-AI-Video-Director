# Default: auto-detect text files and normalize to LF in the repo
* text=auto

# Cross-platform source files — always LF
*.py    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.csv   text eol=lf

# Windows-only scripts — always CRLF
*.bat   text eol=crlf

# Binary files — no line ending conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.mp3   binary
*.mp4   binary
*.wav   binary
